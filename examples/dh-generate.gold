let makeUser = (user) => {
    let home = "/home/${user}"
    let privateKey = "${home}/.ssh/id_ed25519"
    let publicKey = "${privateKey}.pub"
    {
        home: home,
        privateKey: privateKey,
        publicKey: publicKey,
    }
}

let buildUser = (index) => makeUser("build${index}")

map(buildUser, range(10))
